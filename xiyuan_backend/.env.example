# MongoDB connection string (required)
MONGODB_URI=mongodb://localhost:27017/xiyuan_blockchain

# Ethereum node RPC URL
RPC_URL=http://localhost:8545

# Deployed smart contract address
CONTRACT_ADDRESS=

# Wallet private key (for signing transactions)
PRIVATE_KEY=

# IPFS configuration (optional, uses local IPFS if not set)
IPFS_API_PORT=5002
IPFS_PROJECT_ID=
IPFS_SECRET=

# BERT semantic similarity service URL (optional)
BERT_SERVICE_URL=http://localhost:5001

# papers.db path (optional, defaults to xiyuan_backend/papers.db)
PAPERS_DB_PATH=
